# Configuración de Soketi/Pusher
# Copia este archivo y configura las variables de entorno en tu plataforma de despliegue

# App Key de Soketi
PUSHER_APP_KEY=app-key

# Host del servidor Soketi (IP o dominio)
PUSHER_WS_HOST=127.0.0.1

# Puerto WebSocket de Soketi
PUSHER_WS_PORT=6001

# Forzar TLS (true para producción, false para desarrollo)
PUSHER_FORCE_TLS=false

# Cluster requerido por el protocolo Pusher
PUSHER_CLUSTER=mt1

# Nombre del canal de chat
PUSHER_CHANNEL=chat-room
